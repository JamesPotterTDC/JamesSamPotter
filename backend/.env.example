# Django
DEBUG=False
DJANGO_SECRET_KEY=your-secret-key-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,backend,your-app.railway.app
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend.vercel.app
CSRF_TRUSTED_ORIGINS=http://localhost:3000,https://your-frontend.vercel.app

# Database (Railway provides DATABASE_URL automatically)
DATABASE_URL=postgresql://user:pass@host:port/dbname
# Local dev fallback:
POSTGRES_DB=cycling_dashboard
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis/Celery (Railway provides REDIS_URL automatically)
REDIS_URL=redis://default:password@host:port
# Local dev fallback:
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Strava API
STRAVA_CLIENT_ID=your_strava_client_id
STRAVA_CLIENT_SECRET=your_strava_client_secret
STRAVA_WEBHOOK_VERIFY_TOKEN=your_random_webhook_verify_token

# Frontend
FRONTEND_URL=http://localhost:3000

# Admin API
ADMIN_API_TOKEN=your_admin_token_change_in_production

# Encryption (for token storage)
ENCRYPTION_KEY=generate_with_fernet_key_command

# Privacy Settings
MAP_REDACT_PERCENT=10
STRAVA_FETCH_STREAMS=False
